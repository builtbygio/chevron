#!/usr/bin/env node

'use strict';

// Stock Atom bootstrap assumes Node ~12–16 and Python with stdlib distutils.
// On modern macOS (Node 20+/24, Python 3.12+) it fails with:
//   ValueError: invalid mode: 'rU'          (old node-gyp + Python 3.11+)
//   Cannot assign to read only property 'cflags'  (node-gyp 5 + Node 18+)
//
// Use the modern wrapper instead (patches gyp, defers apm natives to Node 12):
//   ./script/bootstrap-modern
//   ./script/with-modern-env ./script/build --no-bootstrap

console.error('');
console.error('error: ./script/bootstrap is not supported on modern host toolchains.');
console.error('');
console.error('  Use:');
console.error('    nvm use          # .nvmrc → Node 24');
console.error('    ./script/bootstrap-modern');
console.error('    ./script/with-modern-env ./script/build --no-bootstrap');
console.error('');
console.error('  See docs/bootstrap-report.md and docs/toolchain-node-python-upgrade-plan.md');
console.error('');
process.exit(1);
