{
  "name": "welcome",
  "version": "0.36.9",
  "description": "Welcome users to Chevron with useful information",
  "main": "./lib/main",
  "atomTestRunner": "atom-mocha-test-runner",
  "repository": "https://github.com/builtbygio/chevron",
  "license": "MIT",
  "engines": {
    "atom": ">0.50.0"
  },
  "scripts": {
    "lint": "standard",
    "test": "atom --test test/*.test.js"
  },
  "consumedServices": {
    "metrics-reporter": {
      "versions": {
        "^1.1.0": "consumeReporter"
      }
    }
  },
  "configSchema": {
    "showOnStartup": {
      "type": "boolean",
      "default": true,
      "description": "Show the Welcome and Welcome Guide panes when opening a new Chevron window. Uncheck to stop auto-opening."
    }
  },
  "deserializers": {
    "WelcomeView": "createWelcomeView",
    "GuideView": "createGuideView"
  },
  "dependencies": {
    "etch": "0.9.0"
  },
  "devDependencies": {
    "atom-mocha-test-runner": "^1.0.0",
    "standard": "^8.6.0"
  },
  "standard": {
    "globals": [
      "atom"
    ]
  }
}
